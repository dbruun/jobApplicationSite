{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "2193288029660245941"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources. Defaults to the resource group location."
      }
    },
    "environmentName": {
      "type": "string",
      "minLength": 3,
      "maxLength": 24,
      "metadata": {
        "description": "Short environment prefix used to derive all resource names (e.g. hhsc-jobportal-prod). Must be lowercase, alphanumeric with hyphens."
      }
    },
    "sqlAdminLogin": {
      "type": "string",
      "metadata": {
        "description": "SQL Server local administrator login (used only for initial provisioning; Entra-only auth is enforced afterwards)."
      }
    },
    "sqlAdminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "SQL Server local administrator password."
      }
    },
    "sqlEntraAdminObjectId": {
      "type": "string",
      "metadata": {
        "description": "Object ID (GUID) of the Entra ID user or group that becomes the SQL Server Entra administrator."
      }
    },
    "sqlEntraAdminLogin": {
      "type": "string",
      "metadata": {
        "description": "UPN or display name of the Entra ID user or group for the SQL Entra administrator."
      }
    },
    "containerAppPrincipalId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Principal ID of the Container App managed identity. Used to assign Storage Blob Data Contributor on the storage account. Leave empty ('') to skip the RBAC assignment (e.g. before the Container App exists)."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "sql-deployment",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "location": {
            "value": "[parameters('location')]"
          },
          "environmentName": {
            "value": "[parameters('environmentName')]"
          },
          "sqlAdminLogin": {
            "value": "[parameters('sqlAdminLogin')]"
          },
          "sqlAdminPassword": {
            "value": "[parameters('sqlAdminPassword')]"
          },
          "sqlEntraAdminObjectId": {
            "value": "[parameters('sqlEntraAdminObjectId')]"
          },
          "sqlEntraAdminLogin": {
            "value": "[parameters('sqlEntraAdminLogin')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.42.1.51946",
              "templateHash": "17835498542650820227"
            }
          },
          "parameters": {
            "location": {
              "type": "string",
              "metadata": {
                "description": "Azure region for all resources."
              }
            },
            "environmentName": {
              "type": "string",
              "metadata": {
                "description": "Environment name prefix used to derive resource names (e.g. hhsc-jobportal-prod)."
              }
            },
            "sqlAdminLogin": {
              "type": "string",
              "metadata": {
                "description": "SQL Server local administrator login (used for initial provisioning)."
              }
            },
            "sqlAdminPassword": {
              "type": "securestring",
              "metadata": {
                "description": "SQL Server local administrator password."
              }
            },
            "sqlEntraAdminObjectId": {
              "type": "string",
              "metadata": {
                "description": "Object ID (GUID) of the Entra ID user or group to set as the SQL Server Entra admin."
              }
            },
            "sqlEntraAdminLogin": {
              "type": "string",
              "metadata": {
                "description": "UPN or display name of the Entra ID user or group for the SQL Server Entra admin."
              }
            }
          },
          "variables": {
            "sqlServerName": "[format('{0}-sql', parameters('environmentName'))]",
            "sqlDatabaseName": "JobApplicationSiteDb"
          },
          "resources": [
            {
              "type": "Microsoft.Sql/servers",
              "apiVersion": "2023-05-01-preview",
              "name": "[variables('sqlServerName')]",
              "location": "[parameters('location')]",
              "properties": {
                "administratorLogin": "[parameters('sqlAdminLogin')]",
                "administratorLoginPassword": "[parameters('sqlAdminPassword')]",
                "minimalTlsVersion": "1.2",
                "publicNetworkAccess": "Enabled"
              }
            },
            {
              "type": "Microsoft.Sql/servers/administrators",
              "apiVersion": "2023-05-01-preview",
              "name": "[format('{0}/{1}', variables('sqlServerName'), 'ActiveDirectory')]",
              "properties": {
                "administratorType": "ActiveDirectory",
                "login": "[parameters('sqlEntraAdminLogin')]",
                "sid": "[parameters('sqlEntraAdminObjectId')]",
                "tenantId": "[tenant().tenantId]"
              },
              "dependsOn": [
                "[resourceId('Microsoft.Sql/servers', variables('sqlServerName'))]"
              ]
            },
            {
              "type": "Microsoft.Sql/servers/azureADOnlyAuthentications",
              "apiVersion": "2023-05-01-preview",
              "name": "[format('{0}/{1}', variables('sqlServerName'), 'Default')]",
              "properties": {
                "azureADOnlyAuthentication": true
              },
              "dependsOn": [
                "[resourceId('Microsoft.Sql/servers/administrators', variables('sqlServerName'), 'ActiveDirectory')]",
                "[resourceId('Microsoft.Sql/servers', variables('sqlServerName'))]"
              ]
            },
            {
              "type": "Microsoft.Sql/servers/firewallRules",
              "apiVersion": "2023-05-01-preview",
              "name": "[format('{0}/{1}', variables('sqlServerName'), 'AllowAzureServices')]",
              "properties": {
                "startIpAddress": "0.0.0.0",
                "endIpAddress": "0.0.0.0"
              },
              "dependsOn": [
                "[resourceId('Microsoft.Sql/servers', variables('sqlServerName'))]"
              ]
            },
            {
              "type": "Microsoft.Sql/servers/databases",
              "apiVersion": "2023-05-01-preview",
              "name": "[format('{0}/{1}', variables('sqlServerName'), variables('sqlDatabaseName'))]",
              "location": "[parameters('location')]",
              "sku": {
                "name": "GP_S_Gen5",
                "tier": "GeneralPurpose",
                "family": "Gen5",
                "capacity": 1
              },
              "properties": {
                "collation": "SQL_Latin1_General_CP1_CI_AS",
                "maxSizeBytes": 34359738368,
                "zoneRedundant": false,
                "licenseType": "LicenseIncluded",
                "minCapacity": "[json('0.5')]",
                "autoPauseDelay": 60
              },
              "dependsOn": [
                "[resourceId('Microsoft.Sql/servers', variables('sqlServerName'))]"
              ]
            }
          ],
          "outputs": {
            "sqlServerFqdn": {
              "type": "string",
              "metadata": {
                "description": "Fully-qualified domain name of the SQL Server."
              },
              "value": "[reference(resourceId('Microsoft.Sql/servers', variables('sqlServerName')), '2023-05-01-preview').fullyQualifiedDomainName]"
            },
            "sqlServerName": {
              "type": "string",
              "metadata": {
                "description": "Name of the SQL Server resource."
              },
              "value": "[variables('sqlServerName')]"
            },
            "sqlDatabaseName": {
              "type": "string",
              "metadata": {
                "description": "Name of the SQL Database."
              },
              "value": "[variables('sqlDatabaseName')]"
            }
          }
        }
      }
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "storage-deployment",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "location": {
            "value": "[parameters('location')]"
          },
          "environmentName": {
            "value": "[parameters('environmentName')]"
          },
          "containerAppPrincipalId": {
            "value": "[parameters('containerAppPrincipalId')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.42.1.51946",
              "templateHash": "5234458359502987971"
            }
          },
          "parameters": {
            "location": {
              "type": "string",
              "metadata": {
                "description": "Azure region for all resources."
              }
            },
            "environmentName": {
              "type": "string",
              "metadata": {
                "description": "Environment name prefix used to derive resource names (e.g. hhsc-jobportal-prod)."
              }
            },
            "containerAppPrincipalId": {
              "type": "string",
              "defaultValue": "",
              "metadata": {
                "description": "Principal ID of the Container App managed identity that needs access to Blob Storage. Leave empty to skip RBAC assignment."
              }
            }
          },
          "variables": {
            "storageAccountName": "[toLower(take(format('{0}stor', replace(replace(parameters('environmentName'), '-', ''), '_', '')), 24))]",
            "resumesContainerName": "resumes",
            "storageBlobDataContributorRoleId": "ba92f5b4-2d11-453d-a403-e96b0029c9fe"
          },
          "resources": [
            {
              "type": "Microsoft.Storage/storageAccounts",
              "apiVersion": "2023-05-01",
              "name": "[variables('storageAccountName')]",
              "location": "[parameters('location')]",
              "sku": {
                "name": "Standard_LRS"
              },
              "kind": "StorageV2",
              "properties": {
                "accessTier": "Hot",
                "supportsHttpsTrafficOnly": true,
                "minimumTlsVersion": "TLS1_2",
                "allowBlobPublicAccess": false,
                "allowSharedKeyAccess": true
              }
            },
            {
              "type": "Microsoft.Storage/storageAccounts/blobServices",
              "apiVersion": "2023-05-01",
              "name": "[format('{0}/{1}', variables('storageAccountName'), 'default')]",
              "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
              ]
            },
            {
              "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
              "apiVersion": "2023-05-01",
              "name": "[format('{0}/{1}/{2}', variables('storageAccountName'), 'default', variables('resumesContainerName'))]",
              "properties": {
                "publicAccess": "None"
              },
              "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts/blobServices', variables('storageAccountName'), 'default')]"
              ]
            },
            {
              "condition": "[not(empty(parameters('containerAppPrincipalId')))]",
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "scope": "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]",
              "name": "[guid(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), parameters('containerAppPrincipalId'), variables('storageBlobDataContributorRoleId'))]",
              "properties": {
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('storageBlobDataContributorRoleId'))]",
                "principalId": "[parameters('containerAppPrincipalId')]",
                "principalType": "ServicePrincipal"
              },
              "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
              ]
            }
          ],
          "outputs": {
            "storageAccountUri": {
              "type": "string",
              "metadata": {
                "description": "Blob service endpoint URI (use as AzureStorage:AccountUri in app config)."
              },
              "value": "[reference(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2023-05-01').primaryEndpoints.blob]"
            },
            "storageAccountName": {
              "type": "string",
              "metadata": {
                "description": "Name of the storage account resource."
              },
              "value": "[variables('storageAccountName')]"
            },
            "resumesContainerName": {
              "type": "string",
              "metadata": {
                "description": "Name of the resumes blob container."
              },
              "value": "[variables('resumesContainerName')]"
            }
          }
        }
      }
    }
  ],
  "outputs": {
    "sqlServerFqdn": {
      "type": "string",
      "metadata": {
        "description": "Fully-qualified domain name of the Azure SQL Server."
      },
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'sql-deployment'), '2025-04-01').outputs.sqlServerFqdn.value]"
    },
    "sqlDatabaseName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Azure SQL Database."
      },
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'sql-deployment'), '2025-04-01').outputs.sqlDatabaseName.value]"
    },
    "connectionString": {
      "type": "string",
      "metadata": {
        "description": "Ready-to-use connection string for the application (Managed Identity / Active Directory Default auth)."
      },
      "value": "[format('Server=tcp:{0},1433;Database={1};Authentication=Active Directory Default;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;', reference(resourceId('Microsoft.Resources/deployments', 'sql-deployment'), '2025-04-01').outputs.sqlServerFqdn.value, reference(resourceId('Microsoft.Resources/deployments', 'sql-deployment'), '2025-04-01').outputs.sqlDatabaseName.value)]"
    },
    "storageAccountUri": {
      "type": "string",
      "metadata": {
        "description": "Blob service endpoint URI — set as AzureStorage:AccountUri in app configuration."
      },
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'storage-deployment'), '2025-04-01').outputs.storageAccountUri.value]"
    },
    "resumesContainerName": {
      "type": "string",
      "metadata": {
        "description": "Name of the resumes blob container."
      },
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'storage-deployment'), '2025-04-01').outputs.resumesContainerName.value]"
    }
  }
}