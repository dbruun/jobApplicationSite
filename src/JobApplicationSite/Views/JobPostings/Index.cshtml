@model List<JobApplicationSite.Models.JobPosting>
@{
    ViewData["Title"] = "Job Postings";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Job Postings</h1>
    <a asp-action="Create" class="btn btn-primary">+ New Posting</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No job postings yet. <a asp-action="Create">Create the first one.</a></div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Posting #</th>
                    <th>Title</th>
                    <th>Department</th>
                    <th>Location</th>
                    <th>Posted</th>
                    <th>Closes</th>
                    <th>Status</th>
                    <th>Apps</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var posting in Model)
                {
                    <tr>
                        <td><code>@posting.PostingNumber</code></td>
                        <td>@posting.Title</td>
                        <td>@posting.Department</td>
                        <td>@posting.Location</td>
                        <td>@posting.PostedDate.ToString("MM/dd/yyyy")</td>
                        <td>@(posting.ClosingDate?.ToString("MM/dd/yyyy") ?? "—")</td>
                        <td>
                            @if (posting.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td>
                            <a asp-controller="Applications" asp-action="ForJob" asp-route-id="@posting.Id"
                               class="badge bg-info text-decoration-none text-dark">
                                @posting.Applications.Count
                            </a>
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Edit" asp-route-id="@posting.Id" class="btn btn-outline-primary">Edit</a>
                                <a asp-controller="Applications" asp-action="ForJob" asp-route-id="@posting.Id"
                                   class="btn btn-outline-success">Applications</a>
                                <a asp-controller="Applications" asp-action="Submit" asp-route-id="@posting.Id"
                                   class="btn btn-outline-secondary">Submit Link</a>
                                <a asp-action="Delete" asp-route-id="@posting.Id" class="btn btn-outline-danger">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
